# Copy this file to .env and update values

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

DEFAULT_CAPACITY=10
DEFAULT_REFILL_RATE=1.0

# true  = allow requests when Redis is down (high availability)
# false = reject requests when Redis is down (strict safety)
FAIL_OPEN=true

BUCKET_TTL=3600
